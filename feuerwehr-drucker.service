[Unit]
Description=Feuerwehr Alarmfax-Drucker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/feuerwehr-drucker
ExecStart=/usr/bin/python3 /home/pi/feuerwehr-drucker/drucker.py
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
